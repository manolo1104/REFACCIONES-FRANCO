{
  "version": 2,
  "builds": [
    {
      "src": "PAGINA/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "PAGINA/IMAGENES/**",
      "use": "@vercel/static"
    },
    {
      "src": "DASHBOARD/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "DASHBOARD/server.js"
    },
    {
      "src": "^/dashboard$",
      "dest": "DASHBOARD/server.js"
    },
    {
      "src": "^/$",
      "dest": "PAGINA/index.html"
    },
    {
      "src": "^/(IMAGENES/.*)",
      "dest": "PAGINA/$1"
    }
  ]
}
